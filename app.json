{
  "expo": {
    "name": "Trackr",
    "slug": "trackr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trackr",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "bundleIdentifier": "ltd.siryus.trackr"
    },
    "android": {
      "package": "ltd.siryus.trackr",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["USE_BIOMETRIC", "USE_FINGERPRINT", "SCHEDULE_EXACT_ALARM"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2563EB",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-sharing",
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Trackr to unlock with Face ID."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Trackr to attach product photos."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
